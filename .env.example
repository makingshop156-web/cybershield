# Supabase (required for auth & database)
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Production URL (used for CORS)
NEXT_PUBLIC_APP_URL=https://cybershield-nu-one.vercel.app

# Sentry (error tracking — optional)
# https://sentry.io/settings/YOUR_ORG/projects/YOUR_PROJECT/keys/
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project

# Resend (email delivery — optional)
RESEND_API_KEY=re_example_key_here
